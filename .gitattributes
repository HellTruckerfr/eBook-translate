# Normalise les fins de ligne : LF dans le dépôt, conversion auto selon l'OS au checkout
* text=auto

# Toujours LF pour les scripts shell et configs
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Scripts Windows : CRLF obligatoire
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.nsh   text eol=crlf

# Binaires
*.exe   binary
*.db    binary
*.png   binary
*.ico   binary
*.whl   binary
